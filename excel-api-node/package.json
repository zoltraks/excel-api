{
  "name": "excel-api-node",
  "version": "0.0.1",
  "description": "Excel API — Node.js/TypeScript implementation",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "bcrypt": "^5.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT"
}
